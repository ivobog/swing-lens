# SwingLens local settings
APP_NAME=SwingLens
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# Local PostgreSQL
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/swinglens

# Local storage
UPLOAD_DIR=data/uploads
EXPORT_DIR=data/exports
CACHE_DIR=data/cache

# Interactive Brokers Gateway defaults
# IB Gateway paper commonly uses 4002. Live commonly uses 4001.
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=21
IB_TIMEOUT_SECONDS=30
IB_USE_RTH=true
IB_DEFAULT_DURATION="2 Y"
IB_DEFAULT_BAR_SIZE="1 day"
IB_REQUEST_DELAY_SECONDS=0.25
